#!/usr/bin/env python3

import json
import os
import signal
import subprocess
import sys
import time

GRACE_MS = 200


def run_json(cmd):
    try:
        out = subprocess.check_output(cmd, text=True, stderr=subprocess.DEVNULL)
        return json.loads(out)
    except Exception:
        return None


def rofi_pids():
    try:
        out = subprocess.check_output(["pgrep", "-x", "rofi"], text=True)
        return [int(x) for x in out.split()]
    except subprocess.CalledProcessError:
        return []


def cursor_pos():
    data = run_json(["hyprctl", "cursorpos", "-j"])
    if isinstance(data, dict) and "x" in data and "y" in data:
        return int(data["x"]), int(data["y"])
    try:
        out = subprocess.check_output(["hyprctl", "cursorpos"], text=True)
        x, y = out.strip().replace(" ", "").split(",", 1)
        return int(float(x)), int(float(y))
    except Exception:
        return None


def walk(obj):
    if isinstance(obj, dict):
        yield obj
        for value in obj.values():
            yield from walk(value)
    elif isinstance(obj, list):
        for value in obj:
            yield from walk(value)


def get_rofi_layer_rects():
    data = run_json(["hyprctl", "layers", "-j"])
    if data is None:
        return []
    rects = []
    for obj in walk(data):
        if str(obj.get("namespace", "")) != "rofi":
            continue
        x = obj.get("x")
        y = obj.get("y")
        w = obj.get("w", obj.get("width"))
        h = obj.get("h", obj.get("height"))
        pid = obj.get("pid")
        if None in (x, y, w, h):
            continue
        try:
            rects.append({"x": int(x), "y": int(y), "w": int(w), "h": int(h),
                          "pid": int(pid) if pid is not None else None})
        except Exception:
            continue
    return rects


def process_age_ms(pid):
    try:
        with open(f"/proc/{pid}/stat", "r") as f:
            start_ticks = int(f.read().split()[21])
        with open("/proc/uptime", "r") as f:
            uptime_seconds = float(f.read().split()[0])
        hz = os.sysconf(os.sysconf_names["SC_CLK_TCK"])
        now_ticks = int(uptime_seconds * hz)
        return int((now_ticks - start_ticks) * 1000 / hz)
    except Exception:
        return 999999


def point_inside(px, py, rect):
    return rect["x"] <= px < rect["x"] + rect["w"] and rect["y"] <= py < rect["y"] + rect["h"]


def main():
    pids = rofi_pids()
    if not pids:
        return 0

    rects = get_rofi_layer_rects()
    if not rects:
        return 0

    pos = cursor_pos()
    if pos is None:
        return 0

    px, py = pos

    if any(point_inside(px, py, rect) for rect in rects):
        return 0

    for pid in pids:
        if process_age_ms(pid) < GRACE_MS:
            return 0

    for rect in rects:
        pid = rect.get("pid")
        if pid:
            try:
                os.kill(pid, signal.SIGTERM)
            except (ProcessLookupError, PermissionError):
                pass

    for pid in pids:
        try:
            os.kill(pid, signal.SIGTERM)
        except (ProcessLookupError, PermissionError):
            pass

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
