{
    "layer": "top",
    "position": "top",
    "height": 30,
    "margin": "4 8 0 8",

    "group/nav": {
        "orientation": "horizontal",
        "modules": ["hyprland/workspaces"]
    },

    "modules-left":   ["group/nav"],
    "modules-center": ["custom/visualizer"],
    "modules-right":  ["group/group-volume", "custom/network", "tray", "clock", "custom/notification"],

    "include": ["~/.config/waybar/modules.jsonc"]
}
