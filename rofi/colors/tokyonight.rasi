* {
    bg:          rgba(8, 8, 11, 0.95);
    fg:          #acb0d0;
    dim:         #787c99;
    accent:      #7aa2f7;
    urgent:      #f7768e;

    accent-fade: rgba(122, 162, 247, 0.10);
    accent-edge: rgba(122, 162, 247, 0.15);
    accent-sep:  rgba(122, 162, 247, 0.08);
    urgent-fade: rgba(247, 118, 142, 0.10);
}
